{
  "name": "quentin-rospars-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "start": "astro dev --host 127.0.0.1 --port 4321",
    "clean": "rm -rf dist playwright-report test-results .lighthouseci",
    "clean:cache": "npm run clean && rm -rf .astro",
    "dev:reset": "npm run clean:cache && npm run dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.6",
    "@astrojs/sitemap": "3.7.3",
    "astro": "6.4.8",
    "gsap": "3.15.0",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1",
    "typescript": "6.0.3",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
