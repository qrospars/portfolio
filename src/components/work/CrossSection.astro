---
import { Image } from 'astro:assets';
import type { WorkPreview } from '@/lib/work';
import { withBase } from '@/lib/urls';

interface Props {
  items: WorkPreview[];
}

const { items } = Astro.props;
---

<div class="cross-section">
  {items.map((item, index) => (
    <article class="cross-card" data-reveal>
      <a href={withBase(item.href)}>
        <div class="cross-card__media">
          <Image
            src={item.image}
            alt={item.imageAlt}
            widths={[480, 768, 1100]}
            sizes="(max-width: 48rem) 100vw, 42vw"
            loading={index < 2 ? 'eager' : 'lazy'}
            quality={84}
          />
        </div>
        <div class="cross-card__copy">
          <span class="eyebrow eyebrow--accent">{item.kind}</span>
          <h3>{item.title}</h3>
          <span class="cross-card__meta">{item.disciplineLabels.join(' · ')}{item.year ? ` — ${item.year}` : ''}</span>
        </div>
      </a>
    </article>
  ))}
</div>

<style>
  .cross-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 2rem);
    align-items: end;
  }

  .cross-card {
    min-width: 0;
  }

  .cross-card a {
    display: grid;
    gap: var(--space-4);
    text-decoration: none;
  }

  .cross-card__media {
    overflow: hidden;
    border-radius: var(--radius-small);
    background: var(--color-paper-deep);
  }

  .cross-card__media :global(img) {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out), filter var(--duration-base) var(--ease-out);
  }

  .cross-card a:hover .cross-card__media :global(img),
  .cross-card a:focus-visible .cross-card__media :global(img) {
    transform: scale(1.025);
  }

  .cross-card__copy {
    display: grid;
    gap: var(--space-2);
  }

  .cross-card h3 {
    margin: 0;
    font-size: var(--step-2);
    transition: color var(--duration-base) var(--ease-out);
  }

  .cross-card a:hover h3,
  .cross-card a:focus-visible h3 {
    color: var(--color-coral);
  }

  .cross-card__meta {
    color: var(--text-muted);
    font-family: var(--font-mono-stack);
    font-size: var(--step--1);
  }

  @media (max-width: 48rem) {
    .cross-section {
      grid-template-columns: 1fr;
    }

  }
</style>
