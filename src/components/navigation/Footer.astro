---
import { withBase } from '@/lib/urls';
---

<footer class="site-footer">
  <div class="container container--wide site-footer__inner">
    <div class="site-footer__invitation">
      <p class="eyebrow eyebrow--accent">Contact</p>
      <p class="site-footer__title">If you think I am someone interesting to talk to, don't hesitate to send me an email.</p>
      <a class="site-footer__email" href="mailto:rospars.quentin@outlook.com">rospars.quentin@outlook.com <span aria-hidden="true">↗</span></a>
    </div>
    <div class="site-footer__bottom">
      <span class="eyebrow">© {new Date().getFullYear()} Quentin Rospars</span>
      <nav aria-label="Social links">
        <a href="https://www.linkedin.com/in/quentin-rospars-a073b6150/" rel="noreferrer" target="_blank">LinkedIn</a>
        <a href="https://www.instagram.com/quentin_rsprs/" rel="noreferrer" target="_blank">Instagram</a>
        <a href="https://github.com/qrospars" rel="noreferrer" target="_blank">GitHub</a>
        <a href={withBase('/')}>Top ↑</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --text-muted: var(--color-dark-muted);
    --text-accent: var(--color-coral-soft);

    position: relative;
    z-index: var(--z-content);
    padding-block: var(--space-8) var(--space-5);
    background: var(--color-dark);
    color: var(--color-white);
  }

  .site-footer__inner {
    display: grid;
    gap: var(--space-8);
  }

  .site-footer__invitation {
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) minmax(18rem, 2fr);
    gap: var(--space-6);
    align-items: start;
  }

  .site-footer__title {
    max-width: 58rem;
    margin: 0;
    font-family: var(--font-display-stack);
    font-size: var(--step-3);
    line-height: 1.05;
  }

  .site-footer__email {
    grid-column: 2;
    width: fit-content;
    font-size: var(--step-0);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--space-5);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-dark-line);
  }

  .site-footer__bottom nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
  }

  .site-footer__bottom a {
    font-size: var(--step--1);
  }

  @media (max-width: 42rem) {
    .site-footer__invitation {
      grid-template-columns: 1fr;
    }

    .site-footer__email {
      grid-column: 1;
      overflow-wrap: anywhere;
    }

    .site-footer__bottom {
      flex-direction: column;
    }
  }
</style>
