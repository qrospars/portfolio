---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import profileImage from '@/assets/profile/quentin-rospars.jpg';
import { PROFILE } from '@/config/profile';
---

<BaseLayout title="About — Quentin Rospars" description={PROFILE.defaultDescription}>
  <section class="about-page section" aria-labelledby="about-title">
    <div class="container container--wide about-page__grid">
      <header>
        <p class="eyebrow eyebrow--accent">About</p>
        <h1 id="about-title" tabindex="-1" data-route-heading>Hi, I'm Quentin.</h1>
      </header>
      <div class="about-page__portrait">
        <Image
          src={profileImage}
          alt="Portrait of Quentin Rospars"
          widths={[480, 720, 960]}
          sizes="(max-width: 48rem) calc(100vw - 2.5rem), 38vw"
          loading="eager"
          quality={85}
        />
      </div>
      <div class="about-page__copy stack">
        <p>{PROFILE.about[0]}</p>
        <p>{PROFILE.about[1]}</p>
        <p>{PROFILE.about[2]}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    padding-top: clamp(9rem, 18vh, 14rem);
  }

  .about-page__grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--space-6);
    align-items: start;
  }

  header {
    grid-column: 1 / span 8;
    margin-bottom: var(--space-7);
  }

  h1 {
    margin: var(--space-3) 0 0;
    font-size: var(--step-5);
  }

  .about-page__portrait {
    grid-column: 1 / span 5;
    overflow: hidden;
    border-radius: var(--radius-small);
  }

  .about-page__portrait :global(img) {
    aspect-ratio: 4 / 5;
    object-fit: cover;
    filter: saturate(0.75);
  }

  .about-page__copy {
    --stack-space: var(--space-6);
    grid-column: 7 / -1;
    font-size: var(--step-1);
  }

  @media (max-width: 48rem) {
    .about-page__grid {
      grid-template-columns: 1fr;
    }

    header,
    .about-page__portrait,
    .about-page__copy {
      grid-column: 1;
    }
  }
</style>
